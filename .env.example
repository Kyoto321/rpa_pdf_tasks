# ──────────────────────────────────
# Environment Variables – rpa-pdf-tasks
# Copy to .env and fill in values
# ──────────────────────────────────

# ============ Quest 1 & 4: Crawler ============
# (Optional) If iros.go.kr requires login credentials in future:
# IROS_USER_ID=your_id_here
# IROS_PASSWORD=your_password_here

# Run crawler in headed (visible) mode for debugging: set to "1" to enable
HEADED=

# ============ Quest 4: Scheduler ============
# Cron expression for scheduled crawls (default: every hour)
CRON_SCHEDULE=0 * * * *

# Address to search during scheduled runs
CRAWL_ADDRESS=서울특별시 강남구 테헤란로 152
